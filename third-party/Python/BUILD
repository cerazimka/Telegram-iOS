# Python.xcframework is managed via http_archive in MODULE.bazel.
# It is downloaded automatically during `bazel build` as @python_apple_support.
#
# Locally the xcframework is in Python.xcframework/ (gitignored, 120 MB).
# To fetch it manually:
#   curl -L https://github.com/beeware/Python-Apple-support/releases/download/3.14-b9/Python-3.14-iOS-support.b9.tar.gz \
#        | tar -xz --strip-components=0 -C third-party/Python/
